# =========================
# TEMPLATE REPO .gitignore
# =========================
# This .gitignore is for the BOILERPLATE TEMPLATE itself.
# It commits all agent files so the template is complete on GitHub.
#
# AFTER CLONING for a new project:
#   1. Delete this .gitignore
#   2. Rename .gitignore.project → .gitignore
#   (The Manager does this automatically during /init-project)

# =========================
# Standard Ignores
# =========================

# Dependencies
node_modules/
vendor/
__pycache__/
*.pyc
.venv/
venv/

# Build outputs
dist/
build/
.next/
out/

# Environment & secrets
.env
.env.local
.env.*.local

# IDE
.vscode/settings.json
.idea/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Local agent config overrides (template agents committed, but not user-local settings)
.claude/settings.local.json

# Maintainer-only: build/release artifacts and source packages
vscode-extension/
cli/
website/

# Other Stuff
.agents/_dev
.github/agents/meta-manager.agent.md
.github/agents/meta-researcher.agent.md
HOW_TO_UPDATE.md
.github/scripts/backup.ps1

# Build artifacts & raw source assets
*.vsix
assets/