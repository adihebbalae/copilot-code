# =========================
# Agent System Files
# =========================
# These are the AI agent orchestration files.
# They should NOT be committed to the actual project repository.
# The boilerplate template repo keeps them; cloned projects ignore them.

# Agent state (changes every session, project-specific)
.agents/state.json
.agents/state.md
.agents/handoff.md

# Agent config files (boilerplate — not project code)
.agents/
.github/agents/
.github/prompts/
.github/skills/
.github/copilot-instructions.md

# IDE-specific adapters
.cursor/
.clinerules/
.windsurfrules
.claude/
.gemini/
.boilerplate/
boilerplate.config.json
CLAUDE.md
AGENTS.md
GEMINI.md

# Boilerplate meta files (internal docs, not project code)
# These document the boilerplate itself — not your product.
# They contain proprietary build patterns, agent workflows, and implementation details.
DESIGN.md
ANTIGRAVITY.md
HOW_TO_UPDATE.md
RETROFIT.md

# Boilerplate distribution packages
# The CLI, VS Code extension, and website are the boilerplate's own products.
# They are not part of your project and should not be in its repo.
cli/
vscode-extension/
website/
claude-plugin/

# Boilerplate changelog (replace with your own)
# After init, create your own CHANGELOG.md — don't ship the boilerplate's history.
# Uncomment if you don't want any changelog:
# CHANGELOG.md

# =========================
# Standard Ignores
# =========================

# Dependencies
node_modules/
vendor/
__pycache__/
*.pyc
.venv/
venv/

# Build outputs
dist/
build/
.next/
out/

# Environment & secrets
.env
.env.local
.env.*.local

# IDE
.vscode/settings.json
.idea/

# OS
.DS_Store
Thumbs.db
